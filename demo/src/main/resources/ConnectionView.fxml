<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.project.demo.api.rest.javafx.ConnectionViewController"
            styleClass="connection-view">

    <!-- Consistent margin surrounding the entire layout workspace -->
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <!-- Top Action Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="20"/>
            </BorderPane.margin>

            <Label text="Database Connections" styleClass="title"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="+ Add Connection" onAction="#addConnection" styleClass="primary-button"/>
        </HBox>
    </top>

    <!-- Content Workspace -->
    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="dashboard-scroll"
                    BorderPane.alignment="CENTER">
            <content>
                <!-- FlowPane now automatically wraps based on live window size -->
                <FlowPane fx:id="cardContainer"
                          hgap="16"
                          vgap="16"
                          styleClass="card-container">
                    <padding>
                        <Insets top="4" right="4" bottom="4" left="4"/>
                    </padding>
                </FlowPane>
            </content>
        </ScrollPane>
    </center>

</BorderPane>