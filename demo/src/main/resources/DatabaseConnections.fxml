<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.project.demo.api.desktop.javafx.DatabaseConnectionsController"
            fx:id="dashboardConnection"
            stylesheets="@css/connection.css">
    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="content-scrollpane"
                    BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="24" styleClass="content-container">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <VBox spacing="12" styleClass="card-panel header-hero-card">
                        <padding>
                            <Insets top="24" right="24" bottom="24" left="24"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <HBox>
                                    <Label text="DATABASE" styleClass="status-chip database-tag"/>
                                </HBox>
                                <Label text="Database Connections" styleClass="page-title-large"/>
                                <Label text="Manage PostgreSQL connections used by the migration engine." styleClass="page-subtitle"/>
                            </VBox>
                            <Button text="+ New Connection" styleClass="btn-teal-action" onAction="#addNewConnections"/>
                        </HBox>
                    </VBox>

                    <TilePane fx:id="connectionTilePane"
                              hgap="20"
                              vgap="20"
                              tileAlignment="TOP_LEFT"
                              VBox.vgrow="ALWAYS"/>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>