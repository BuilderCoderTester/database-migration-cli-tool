<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.project.demo.api.rest.javafx.RunHistory"
            stylesheets="@css/run-history.css"
            styleClass="page-root">

    <top>
        <VBox spacing="15" styleClass="page-header">
            <padding>
                <Insets top="25" right="25" bottom="20" left="25"/>
            </padding>

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="EXECUTION HISTORY" styleClass="section-caption"/>
                    <Label text="Migration Run History" styleClass="page-title"/>
                    <Label text="Review previous migration executions, execution time, failures and database changes."
                           wrapText="true" styleClass="page-subtitle"/>
                </VBox>

                <VBox alignment="CENTER" spacing="6" prefWidth="120" prefHeight="100" styleClass="summary-card">
                    <Label text="↻" styleClass="summary-icon"/>
                    <Label text="4" styleClass="summary-value"/>
                    <Label text="Executions" styleClass="summary-label"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="transparent-scroll">
            <content>
                <VBox spacing="12">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <HBox spacing="20" alignment="CENTER_LEFT" styleClass="history-card">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="V3" styleClass="migration-version"/>
                            <Label text="insert into entity" styleClass="migration-title"/>
                            <VBox spacing="2">
                                <Label text="EXECUTED AT" styleClass="field-label"/>
                                <Label text="6/27/2026, 9:00:31 PM" styleClass="field-value"/>
                            </VBox>
                        </VBox>
                        <VBox alignment="CENTER_LEFT" spacing="2" minWidth="100">
                            <Label text="DURATION" styleClass="field-label"/>
                            <Label text="101 ms" styleClass="field-value"/>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" prefWidth="120">
                            <Label text="SUCCESS" styleClass="status-success"/>
                        </HBox>
                    </HBox>

                    <HBox spacing="20" alignment="CENTER_LEFT" styleClass="history-card">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="V4" styleClass="migration-version"/>
                            <Label text="insert into mst" styleClass="migration-title"/>
                            <VBox spacing="2">
                                <Label text="EXECUTED AT" styleClass="field-label"/>
                                <Label text="6/27/2026, 9:00:32 PM" styleClass="field-value"/>
                            </VBox>
                        </VBox>
                        <VBox alignment="CENTER_LEFT" spacing="2" minWidth="100">
                            <Label text="DURATION" styleClass="field-label"/>
                            <Label text="877 ms" styleClass="field-value"/>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" prefWidth="120">
                            <Label text="SUCCESS" styleClass="status-success"/>
                        </HBox>
                    </HBox>

                    <HBox spacing="20" alignment="CENTER_LEFT" styleClass="history-card">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="V2" styleClass="migration-version"/>
                            <Label text="Update table entity" styleClass="migration-title"/>
                            <VBox spacing="2">
                                <Label text="EXECUTED AT" styleClass="field-label"/>
                                <Label text="6/27/2026, 9:30:40 PM" styleClass="field-value"/>
                            </VBox>
                        </VBox>
                        <VBox alignment="CENTER_LEFT" spacing="2" minWidth="100">
                            <Label text="DURATION" styleClass="field-label"/>
                            <Label text="184 ms" styleClass="field-value"/>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" prefWidth="120">
                            <Label text="SUCCESS" styleClass="status-success"/>
                        </HBox>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>