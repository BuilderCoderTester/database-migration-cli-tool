<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.project.demo.api.rest.javafx.SettingsController">

    <top>

        <HBox alignment="CENTER_LEFT"
              spacing="10"
              styleClass="topbar">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Application Settings"
                   styleClass="page-title"/>

        </HBox>

    </top>

    <center>

        <ScrollPane fitToWidth="true">

            <content>

                <VBox spacing="20">

                    <padding>
                        <Insets top="20"
                                right="20"
                                bottom="20"
                                left="20"/>
                    </padding>

                    <!-- General -->

                    <VBox spacing="15"
                          styleClass="dashboard-panel">

                        <Label text="General"
                               styleClass="panel-title"/>

                        <GridPane hgap="20"
                                  vgap="15">

                            <Label text="Application Name"/>
                            <TextField fx:id="appNameField"
                                       GridPane.columnIndex="1"/>

                            <Label text="Workspace"/>
                            <TextField fx:id="workspaceField"
                                       GridPane.columnIndex="1"
                                       GridPane.rowIndex="1"/>

                            <Label text="Migration Folder"/>
                            <TextField fx:id="migrationFolderField"
                                       GridPane.columnIndex="1"
                                       GridPane.rowIndex="2"/>

                            <Button text="Browse"
                                    GridPane.columnIndex="2"
                                    GridPane.rowIndex="2"/>

                        </GridPane>

                    </VBox>

                    <!-- Database -->

                    <VBox spacing="15"
                          styleClass="dashboard-panel">

                        <Label text="Database"
                               styleClass="panel-title"/>

                        <GridPane hgap="20"
                                  vgap="15">

                            <Label text="Default Schema"/>
                            <TextField fx:id="schemaField"
                                       GridPane.columnIndex="1"/>

                            <Label text="Connection Timeout"/>
                            <Spinner fx:id="timeoutSpinner"
                                     GridPane.columnIndex="1"
                                     GridPane.rowIndex="1"/>

                            <Label text="Auto Connect"/>
                            <CheckBox fx:id="autoConnectCheck"
                                      GridPane.columnIndex="1"
                                      GridPane.rowIndex="2"/>

                        </GridPane>

                    </VBox>

                    <!-- Migration -->

                    <VBox spacing="15"
                          styleClass="dashboard-panel">

                        <Label text="Migration"
                               styleClass="panel-title"/>

                        <VBox spacing="10">

                            <CheckBox fx:id="checksumCheck"
                                      text="Enable checksum validation"/>

                            <CheckBox fx:id="backupCheck"
                                      text="Create backup before migration"/>

                            <CheckBox fx:id="transactionCheck"
                                      text="Run migration inside transaction"/>

                            <CheckBox fx:id="lockCheck"
                                      text="Enable migration locking"/>

                        </VBox>

                    </VBox>

                    <!-- AI -->

                    <VBox spacing="15"
                          styleClass="dashboard-panel">

                        <Label text="AI Assistant"
                               styleClass="panel-title"/>

                        <GridPane hgap="20"
                                  vgap="15">

                            <Label text="Provider"/>
                            <ComboBox fx:id="providerCombo"
                                      GridPane.columnIndex="1"/>

                            <Label text="API Key"/>
                            <PasswordField fx:id="apiKeyField"
                                           GridPane.columnIndex="1"
                                           GridPane.rowIndex="1"/>

                            <Label text="Model"/>
                            <ComboBox fx:id="modelCombo"
                                      GridPane.columnIndex="1"
                                      GridPane.rowIndex="2"/>

                        </GridPane>

                    </VBox>

                    <!-- Appearance -->

                    <VBox spacing="15"
                          styleClass="dashboard-panel">

                        <Label text="Appearance"
                               styleClass="panel-title"/>

                        <GridPane hgap="20"
                                  vgap="15">

                            <Label text="Theme"/>
                            <ComboBox fx:id="themeCombo"
                                      GridPane.columnIndex="1"/>

                            <Label text="Font Size"/>
                            <Slider fx:id="fontSlider"
                                    min="10"
                                    max="22"
                                    value="14"
                                    GridPane.columnIndex="1"
                                    GridPane.rowIndex="1"/>

                        </GridPane>

                    </VBox>

                    <!-- Bottom Buttons -->

                    <HBox alignment="CENTER_RIGHT"
                          spacing="10">

                        <Button text="Reset"/>

                        <Button text="Save Settings"/>

                    </HBox>

                </VBox>

            </content>

        </ScrollPane>

    </center>

</BorderPane>