<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.project.demo.api.rest.javafx.TablesController"
            stylesheets="@css/tables.css"
            styleClass="page-root">

    <top>
        <VBox spacing="16" styleClass="page-header">
            <padding>
                <Insets top="24" right="24" bottom="18" left="24"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="METADATA INSPECTION" styleClass="section-caption"/>
                    <Label text="Database Tables Explorer" styleClass="page-title"/>
                </VBox>
                <Button text="Refresh Schema" onAction="#handleRefresh" styleClass="btn-secondary"/>
                <Button text="Export DDL" onAction="#handleExport" styleClass="btn-secondary"/>
            </HBox>

            <HBox spacing="16" alignment="CENTER_LEFT">
                <TextField fx:id="searchField"
                           promptText="Search interactive table schemas..."
                           HBox.hgrow="ALWAYS"
                           styleClass="form-input"/>
                <ComboBox fx:id="schemaCombo"
                          promptText="Select Schema"
                          minWidth="180"
                          prefWidth="220"
                          styleClass="form-combo"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.25"
                   styleClass="dashboard-splitpane"
                   BorderPane.alignment="CENTER">
            <items>

                <VBox spacing="12" minWidth="240" maxWidth="450" styleClass="side-explorer-panel">
                    <padding>
                        <Insets top="20" right="16" bottom="20" left="24"/>
                    </padding>
                    <Label text="Tables" styleClass="panel-title"/>
                    <ListView fx:id="tableList" VBox.vgrow="ALWAYS" styleClass="technical-listview"/>
                </VBox>

                <VBox spacing="16" minWidth="550" styleClass="main-details-panel">
                    <padding>
                        <Insets top="20" right="24" bottom="20" left="16"/>
                    </padding>

                    <VBox spacing="16" styleClass="dashboard-panel" VBox.vgrow="NEVER">
                        <padding>
                            <Insets top="18" right="20" bottom="18" left="20"/>
                        </padding>
                        <Label text="Table Information" styleClass="panel-title"/>

                        <GridPane hgap="24" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints minWidth="120" prefWidth="140" hgrow="NEVER"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="24" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="24" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="24" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="24" vgrow="SOMETIMES"/>
                            </rowConstraints>
                            <children>
                                <Label text="Table Name" styleClass="metadata-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <Label fx:id="tableNameLabel" styleClass="metadata-value" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <Label text="Schema Scope" styleClass="metadata-label" GridPane.rowIndex="1"/>
                                <Label fx:id="schemaLabel" styleClass="metadata-value" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <Label text="Estimated Rows" styleClass="metadata-label" GridPane.rowIndex="2"/>
                                <Label fx:id="rowsLabel" styleClass="metadata-value" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                <Label text="Total Columns" styleClass="metadata-label" GridPane.rowIndex="3"/>
                                <Label fx:id="columnCountLabel" styleClass="metadata-value" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                            </children>
                        </GridPane>
                    </VBox>

                    <VBox spacing="12" styleClass="dashboard-panel" VBox.vgrow="ALWAYS">
                        <padding>
                            <Insets top="18" right="20" bottom="18" left="20"/>
                        </padding>
                        <Label text="Columns Schema Layout" styleClass="panel-title"/>

                        <TableView fx:id="columnTable" VBox.vgrow="ALWAYS" styleClass="schema-tableview">
                            <columns>
                                <TableColumn fx:id="nameColumn" text="Column" minWidth="140"/>
                                <TableColumn fx:id="typeColumn" text="Type" minWidth="110"/>
                                <TableColumn fx:id="nullableColumn" text="Nullable" minWidth="90"/>
                                <TableColumn fx:id="defaultColumn" text="Default Expression" minWidth="140"/>
                                <TableColumn fx:id="keyColumn" text="Key Constraint" minWidth="100"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </VBox>

            </items>
        </SplitPane>
    </center>
</BorderPane>