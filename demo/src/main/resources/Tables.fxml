<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.project.demo.api.rest.javafx.TablesController"
            styleClass="tables-view">

    <!-- ================= HEADER ================= -->
    <top>
        <VBox spacing="15" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="24" right="24" bottom="16" left="24"/>
            </padding>

            <!-- Title & Global Controls -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="Database Tables" styleClass="page-title"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Refresh" styleClass="secondary-button"/>
                <Button text="Export" styleClass="secondary-button"/>
            </HBox>

            <!-- Search & Filters Bar -->
            <HBox spacing="16" alignment="CENTER_LEFT">
                <TextField fx:id="searchField"
                           promptText="Search table..."
                           HBox.hgrow="ALWAYS"
                           styleClass="search-field"/>
                <ComboBox fx:id="schemaCombo"
                          promptText="Schema"
                          minWidth="160"
                          prefWidth="200"
                          styleClass="schema-combo"/>
            </HBox>
        </VBox>
    </top>

    <!-- ================= BODY ================= -->
    <center>
        <SplitPane dividerPositions="0.25"
                   styleClass="dashboard-splitpane"
                   BorderPane.alignment="CENTER">
            <items>

                <!-- LEFT PANEL: Table Explorer List -->
                <VBox spacing="12" minWidth="220" maxWidth="450" SplitPane.resizableWithParent="true">
                    <padding>
                        <Insets top="16" right="12" bottom="24" left="24"/>
                    </padding>
                    <Label text="Tables" styleClass="panel-title"/>
                    <ListView fx:id="tableList" VBox.vgrow="ALWAYS" styleClass="table-listview"/>
                </VBox>

                <!-- RIGHT PANEL: Metadata & Column Schema Details -->
                <VBox spacing="20" minWidth="500" SplitPane.resizableWithParent="true">
                    <padding>
                        <Insets top="16" right="24" bottom="24" left="12"/>
                    </padding>

                    <!-- Structural Information Panel -->
                    <VBox spacing="16" styleClass="dashboard-panel" VBox.vgrow="NEVER">
                        <padding>
                            <Insets top="16" right="20" bottom="16" left="20"/>
                        </padding>
                        <Label text="Table Information" styleClass="panel-title"/>

                        <!-- Added specific column constraints to prevent jumping text layout -->
                        <GridPane hgap="24" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints minWidth="100" prefWidth="120" hgrow="NEVER"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="20" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="20" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="20" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="20" vgrow="SOMETIMES"/>
                            </rowConstraints>
                            <children>
                                <Label text="Table Name" styleClass="metadata-label"/>
                                <Label fx:id="tableNameLabel" styleClass="metadata-value" GridPane.columnIndex="1"/>

                                <Label text="Schema" styleClass="metadata-label" GridPane.rowIndex="1"/>
                                <Label fx:id="schemaLabel" styleClass="metadata-value" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <Label text="Rows" styleClass="metadata-label" GridPane.rowIndex="2"/>
                                <Label fx:id="rowsLabel" styleClass="metadata-value" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                <Label text="Columns" styleClass="metadata-label" GridPane.rowIndex="3"/>
                                <Label fx:id="columnCountLabel" styleClass="metadata-value" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                            </children>
                        </GridPane>
                    </VBox>

                    <!-- Structural Table Columns Schema Detail Panel -->
                    <VBox spacing="12" styleClass="dashboard-panel" VBox.vgrow="ALWAYS">
                        <padding>
                            <Insets top="16" right="20" bottom="16" left="20"/>
                        </padding>
                        <Label text="Columns" styleClass="panel-title"/>

                        <TableView fx:id="columnTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="nameColumn" text="Column" minWidth="130"/>
                                <TableColumn fx:id="typeColumn" text="Type" minWidth="100"/>
                                <TableColumn fx:id="nullableColumn" text="Nullable" minWidth="80"/>
                                <TableColumn fx:id="defaultColumn" text="Default" minWidth="120"/>
                                <TableColumn fx:id="keyColumn" text="Key" minWidth="70"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </VBox>

            </items>
        </SplitPane>
    </center>
</BorderPane>