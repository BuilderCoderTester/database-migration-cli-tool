<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.control.ScrollPane?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.project.demo.api.rest.javafx.DashboardController"
            fx:id="mainPane"
            stylesheets="@css/dashboard.css">

    <left>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    pannable="true"
                    styleClass="sidebar-scroll">
            <content>
                <VBox prefWidth="270" minWidth="270" maxWidth="270" styleClass="sidebar" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets top="20" right="15" bottom="20" left="15"/>
                    </padding>

                    <VBox spacing="4">
                        <Label text="MigrateDB" styleClass="sidebar-logo"/>
                        <Label text="Database Migration Tool" styleClass="sidebar-subtitle"/>
                    </VBox>

                    <Separator styleClass="sidebar-separator"/>

                    <VBox spacing="6">
                        <Label text="NAVIGATION" styleClass="sidebar-title"/>
                        <Button text="🏠 Dashboard"
                                onAction="#handleDashboardHomeClick"
                                maxWidth="Infinity" styleClass="nav-button nav-button-active"/>
                        <Button text="📜 Migration Scripts" onAction="#handleMigrationScriptsClick" maxWidth="Infinity"
                                styleClass="nav-button"/>
                        <Button text="🕒 Run History" maxWidth="Infinity" styleClass="nav-button"
                                onAction="#handelRunHsitory"/>
                    </VBox>

                    <Separator styleClass="sidebar-separator"/>

                    <VBox spacing="6">
                        <Label text="DATABASE" styleClass="sidebar-title"/>
                        <Button text="🔌 Connections" maxWidth="Infinity" styleClass="nav-button"
                                onAction="#handelDatabaseConnection"/>
                        <Button text="🗄 Tables" maxWidth="Infinity" styleClass="nav-button"
                                onAction="#handelDatabaseTables"/>
                    </VBox>

                    <Separator styleClass="sidebar-separator"/>

                    <VBox spacing="6">
                        <Label text="MONITORING" styleClass="sidebar-title"/>
                        <Button text="📋 Activity Logs" onAction="#handelActivityLogs" maxWidth="Infinity"
                                styleClass="nav-button"/>
                    </VBox>

                    <Separator styleClass="sidebar-separator"/>

                    <VBox spacing="6">
                        <Label text="ADMINISTRATION" styleClass="sidebar-title"/>
                        <Button text="💾 Driver Manager" maxWidth="Infinity" styleClass="nav-button"/>
                        <Button text="📂 Migration Paths" maxWidth="Infinity" styleClass="nav-button"/>
                        <Button text="🗄 Database Types" maxWidth="Infinity" styleClass="nav-button"/>
                        <Button text="⚙ Settings" maxWidth="Infinity" styleClass="nav-button"/>
                        <Button text="ℹ About" maxWidth="Infinity" styleClass="nav-button"/>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS"/>
                    <Separator styleClass="sidebar-separator"/>
                    <Label text="Version 1.0" styleClass="sidebar-footer"/>
                </VBox>
            </content>
        </ScrollPane>
    </left>

    <top>
        <BorderPane styleClass="topbar" prefHeight="65" maxHeight="65" minHeight="65" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10" right="24" bottom="10" left="24"/>
            </padding>
            <left>
                <VBox alignment="CENTER_LEFT" spacing="2" BorderPane.alignment="CENTER">
                    <Label text="Database Migration Dashboard" styleClass="page-title"/>
                    <Label text="Manage and monitor database migrations" styleClass="page-subtitle"/>
                </VBox>
            </left>
            <right>
                <HBox alignment="CENTER_RIGHT" spacing="12" BorderPane.alignment="CENTER">
                    <Label text="Production" styleClass="env-chip"/>
                    <Label text="PostgreSQL" styleClass="db-chip"/>
                    <Button text="+ New Migration" styleClass="primary-button"/>
                </HBox>
            </right>
        </BorderPane>
    </top>

    <center>
        <VBox fx:id="dashboardContent" spacing="16" styleClass="dashboard-content" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="16" right="24" bottom="16" left="24"/>
            </padding>

            <BorderPane fx:id="heroContainer" styleClass="hero-card" minHeight="90" prefHeight="95" VBox.vgrow="NEVER">
                <padding>
                    <Insets top="12" right="24" bottom="12" left="24"/>
                </padding>
                <left>
                    <VBox alignment="CENTER_LEFT" spacing="4" BorderPane.alignment="CENTER">
                        <Label text="Welcome to MigrateDB" styleClass="hero-title"/>
                        <Label text="Manage, validate and execute database migrations from one place." wrapText="true"
                               styleClass="hero-subtitle"/>
                        <HBox spacing="8">
                            <Label text="PostgreSQL" styleClass="chip"/>
                            <Label text="Production" styleClass="chip-success"/>
                            <Label text="Connected" styleClass="chip-primary"/>
                        </HBox>
                    </VBox>
                </left>
                <right>
                    <VBox alignment="CENTER_RIGHT" spacing="2" BorderPane.alignment="CENTER">
                        <Label text="Database Status" styleClass="hero-small-title"/>
                        <Label text="Healthy" styleClass="hero-status"/>
                    </VBox>
                </right>
            </BorderPane>

            <GridPane fx:id="quickActionContainer" hgap="16" vgap="16" VBox.vgrow="NEVER">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="100" prefHeight="110" vgrow="SOMETIMES"/>
                </rowConstraints>
                <children>
                    <VBox styleClass="action-card" GridPane.columnIndex="0">
                        <Label text="🚀" styleClass="action-icon"/>
                        <Label text="Run Migration" styleClass="action-title"/>
                        <Label text="Execute all pending scripts." wrapText="true" styleClass="action-description"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Button text="Run" maxWidth="Infinity" styleClass="action-button"/>
                    </VBox>
                    <VBox styleClass="action-card" GridPane.columnIndex="1">
                        <Label text="✔" styleClass="action-icon"/>
                        <Label text="Validate" styleClass="action-title"/>
                        <Label text="Validate checksums." wrapText="true" styleClass="action-description"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Button text="Validate" maxWidth="Infinity" styleClass="action-button"/>
                    </VBox>
                    <VBox styleClass="action-card" GridPane.columnIndex="2">
                        <Label text="🛠" styleClass="action-icon"/>
                        <Label text="Repair" styleClass="action-title"/>
                        <Label text="Repair history after failures." wrapText="true" styleClass="action-description"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Button text="Repair" maxWidth="Infinity" styleClass="action-button"/>
                    </VBox>
                    <VBox styleClass="action-card" GridPane.columnIndex="3">
                        <Label text="↩" styleClass="action-icon"/>
                        <Label text="Rollback" styleClass="action-title"/>
                        <Label text="Rollback latest migration." wrapText="true" styleClass="action-description"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Button text="Rollback" maxWidth="Infinity" styleClass="action-button"/>
                    </VBox>
                </children>
            </GridPane>

            <GridPane fx:id="statisticsContainer" hgap="16" vgap="16" VBox.vgrow="NEVER">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="25.0" hgrow="ALWAYS"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="70" prefHeight="75" vgrow="SOMETIMES"/>
                </rowConstraints>
                <children>
                    <VBox styleClass="stat-card" GridPane.columnIndex="0">
                        <Label text="TOTAL MIGRATIONS" styleClass="stat-title"/>
                        <Label text="08" styleClass="stat-value"/>
                        <Label text="Registered scripts" styleClass="stat-subtitle"/>
                    </VBox>
                    <VBox styleClass="stat-card" GridPane.columnIndex="1">
                        <Label text="APPLIED" styleClass="stat-title"/>
                        <Label text="08" styleClass="stat-success"/>
                        <Label text="Successfully executed" styleClass="stat-subtitle"/>
                    </VBox>
                    <VBox styleClass="stat-card" GridPane.columnIndex="2">
                        <Label text="PENDING" styleClass="stat-title"/>
                        <Label text="00" styleClass="stat-warning"/>
                        <Label text="Waiting to execute" styleClass="stat-subtitle"/>
                    </VBox>
                    <VBox styleClass="stat-card" GridPane.columnIndex="3">
                        <Label text="FAILED" styleClass="stat-title"/>
                        <Label text="00" styleClass="stat-danger"/>
                        <Label text="Execution failures" styleClass="stat-subtitle"/>
                    </VBox>
                </children>
            </GridPane>

            <SplitPane fx:id="tableContainer" dividerPositions="0.5" styleClass="dashboard-splitpane"
                       VBox.vgrow="ALWAYS">
                <items>
                    <VBox spacing="10" styleClass="dashboard-panel" minWidth="200" SplitPane.resizableWithParent="true">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <alignment>TOP_CENTER</alignment>
                        <HBox alignment="CENTER_LEFT" VBox.vgrow="NEVER">
                            <Label text="Pending Migrations" styleClass="panel-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="View All" styleClass="panel-button"/>
                        </HBox>
                        <TableView fx:id="pendingTable" VBox.vgrow="ALWAYS">
                            <placeholder>
                                <Label text="No pending migrations"/>
                            </placeholder>
                            <columns>
                                <TableColumn fx:id="versionColumn" text="Version" prefWidth="100"/>
                                <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="250"/>
                                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </VBox>

                    <VBox spacing="10" styleClass="dashboard-panel" minWidth="200" SplitPane.resizableWithParent="true">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT" VBox.vgrow="NEVER">
                            <Label text="Recent Executions" styleClass="panel-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="History" styleClass="panel-button"/>
                        </HBox>
                        <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                            <placeholder>
                                <Label text="No execution history"/>
                            </placeholder>
                            <columns>
                                <TableColumn fx:id="historyMigrationColumn" text="Migration" prefWidth="200"/>
                                <TableColumn fx:id="historyDateColumn" text="Executed At" prefWidth="150"/>
                                <TableColumn fx:id="historyStatusColumn" text="Status" prefWidth="100"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </items>
            </SplitPane>
        </VBox>
    </center>
</BorderPane>