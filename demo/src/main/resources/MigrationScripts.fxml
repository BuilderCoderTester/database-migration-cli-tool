<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.project.demo.api.rest.javafx.MigrationScriptsController"
            fx:id="scriptPane">

    <!-- ================= HEADER ================= -->

    <top>

        <VBox spacing="15">

            <padding>
                <Insets top="20" right="20" bottom="15" left="20"/>
            </padding>

            <HBox alignment="CENTER_LEFT">

                <Label text="Migration Scripts"
                       styleClass="page-title"/>

                <Pane HBox.hgrow="ALWAYS"/>

                <Button text="+ New Migration"
                        onAction="#createNewMigrations"
                />

                <Button text="Validate"/>

                <Button text="Repair"/>

                <Button text="Preview" onAction="#previewMigrationScripts"/>
                <Button text="Refresh" onAction="#refreshMethod"/>

            </HBox>

            <!-- Filters -->

            <HBox spacing="15">

                <TextField fx:id="searchField"
                           promptText="Search migration..."
                           HBox.hgrow="ALWAYS"/>

                <ComboBox fx:id="statusFilter"
                          promptText="Status"/>

                <ComboBox fx:id="typeFilter"
                          promptText="Type"/>

                <ComboBox fx:id="versionFilter"
                          promptText="Version"/>

            </HBox>

        </VBox>

    </top>

    <!-- ================= CENTER ================= -->

    <center>

        <SplitPane dividerPositions="0.70">

            <!-- Table -->

            <VBox spacing="10">

                <padding>
                    <Insets top="10" right="20" bottom="20" left="20"/>
                </padding>

                <TableView fx:id="migrationTable"
                           VBox.vgrow="ALWAYS">

                    <columns>

                        <TableColumn fx:id="selectColumn"
                                     text=""
                                     prefWidth="40"
                                     resizable="false"/>

                        <TableColumn fx:id="versionColumn"
                                     text="Version"
                                     prefWidth="120"/>

                        <TableColumn fx:id="descriptionColumn"
                                     text="Description"
                                     prefWidth="260"/>

                        <TableColumn fx:id="typeColumn"
                                     text="Type"
                                     prefWidth="100"/>

                        <TableColumn fx:id="statusColumn"
                                     text="Status"
                                     prefWidth="120"/>

                        <TableColumn fx:id="executedColumn"
                                     text="Executed"
                                     prefWidth="170"/>

                        <TableColumn fx:id="durationColumn"
                                     text="Duration"
                                     prefWidth="110"/>

                    </columns>

                </TableView>

            </VBox>

            <!-- Preview -->

            <VBox spacing="15"
                  styleClass="dashboard-panel">

                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>

                <Label text="Migration Preview"
                       styleClass="panel-title"/>

                <GridPane hgap="15" vgap="10">

                    <Label text="Version"/>
                    <Label fx:id="versionLabel" GridPane.columnIndex="1"/>

                    <Label text="Description" GridPane.rowIndex="1"/>
                    <Label fx:id="descriptionLabel"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="1"/>

                    <Label text="Status"
                           GridPane.rowIndex="2"/>
                    <Label fx:id="statusLabel"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="2"/>

                    <Label text="Type"
                           GridPane.rowIndex="3"/>
                    <Label fx:id="typeLabel"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="3"/>

                </GridPane>

                <Label text="UP Script"/>

                <TextArea fx:id="upScriptArea"
                          editable="false"
                          wrapText="false"
                          VBox.vgrow="ALWAYS"/>

                <Label text="DOWN Script"/>

                <TextArea fx:id="downScriptArea"
                          editable="false"
                          wrapText="false"
                          prefHeight="150"/>

                <!-- Action Buttons -->
                <HBox spacing="10"
                      alignment="CENTER_RIGHT">

                    <Button fx:id="migrateButton"
                            text="Migrate"
                            onAction="#handleMigrate"/>

                    <Button fx:id="updateButton"
                            text="Update"
                            onAction="#handleUpdate"/>

                    <Button fx:id="repairButton"
                            text="Repair"
                            onAction="#handleRepair"/>

                    <Button fx:id="rollbackButton"
                            text="Rollback"
                            onAction="#handleRollback"/>

                </HBox>

            </VBox>

        </SplitPane>

    </center>

</BorderPane>