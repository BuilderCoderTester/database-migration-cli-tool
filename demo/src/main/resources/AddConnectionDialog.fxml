<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.demo.api.rest.javafx.AddConnectionController"
      fx:id="root"
      spacing="20"
      prefWidth="750"
      stylesheets="@css/modal.css">

    <padding>
        <Insets top="24" right="24" bottom="20" left="24"/>
    </padding>

    <!-- ================= HEADER SECTION ================= -->
    <HBox alignment="TOP_LEFT">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="NEW CONNECTION" styleClass="modal-badge, connection-badge"/>
            <Label text="Add Database Connection" styleClass="modal-title"/>
            <Label text="Configure a PostgreSQL connection that can be used by the migration engine." styleClass="modal-subtitle"/>
        </VBox>
        <!-- Close Window Cross Button -->
        <Button text="✕" onAction="#handleCancel" styleClass="btn-close-icon"/>
    </HBox>

    <Separator styleClass="modal-separator"/>

    <!-- ================= FORM FIELDS GRID ================= -->
    <GridPane hgap="24" vgap="16" VBox.vgrow="ALWAYS">
        <columnConstraints>
            <ColumnConstraints percentWidth="50"/>
            <ColumnConstraints percentWidth="50"/>
        </columnConstraints>

        <children>
            <!-- Connection Name (Col 0, Row 0) -->
            <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Connection Name" styleClass="input-label-bold"/>
                <TextField fx:id="connectionNameField" promptText="Production Database" styleClass="modal-input-field"/>
            </VBox>

            <!-- Host (Col 1, Row 0) -->
            <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Host" styleClass="input-label-bold"/>
                <TextField fx:id="hostField" promptText="localhost" styleClass="modal-input-field"/>
            </VBox>

            <!-- Port (Col 0, Row 1) -->
            <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="Port" styleClass="input-label-bold"/>
                <TextField fx:id="portField" promptText="5432" styleClass="modal-input-field"/>
            </VBox>

            <!-- Database (Col 1, Row 1) -->
            <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label text="Database" styleClass="input-label-bold"/>
                <TextField fx:id="databaseField" promptText="migration_db" styleClass="modal-input-field"/>
            </VBox>

            <!-- Username (Col 0, Row 2) -->
            <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="2">
                <Label text="Username" styleClass="input-label-bold"/>
                <TextField fx:id="usernameField" promptText="postgres" styleClass="modal-input-field"/>
            </VBox>

            <!-- Password (Col 1, Row 2) -->
            <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <Label text="Password" styleClass="input-label-bold"/>
                <PasswordField fx:id="passwordField" promptText="********" styleClass="modal-input-field"/>
            </VBox>

            <!-- Schema (Spans across both columns at Row 3) -->
            <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2">
                <Label text="Schema" styleClass="input-label-bold"/>
                <TextField fx:id="schemaField" promptText="public" styleClass="modal-input-field"/>
            </VBox>
        </children>
    </GridPane>

    <!-- ================= FOOTER ACTIONS SECTION ================= -->
    <HBox alignment="CENTER_RIGHT" spacing="12">
        <padding>
            <Insets top="16"/>
        </padding>
        <Button text="Cancel" onAction="#handleCancel" styleClass="btn-modal-secondary"/>
        <Button text="Test Connection" onAction="#handleTestConnection" styleClass="btn-modal-neutral"/>
        <Button text="Save Connection" onAction="#handleSaveConnection" styleClass="btn-modal-primary"/>
    </HBox>

</VBox>