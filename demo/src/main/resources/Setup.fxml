<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            prefHeight="550.0"
            prefWidth="700.0"
            fx:controller="com.project.demo.setup.SetupController"
            stylesheets="@css/setup.css"
            styleClass="window-root">

    <children>
        <VBox spacing="18"
              alignment="TOP_LEFT"
              AnchorPane.topAnchor="30"
              AnchorPane.leftAnchor="50"
              AnchorPane.rightAnchor="50"
              AnchorPane.bottomAnchor="30"
              styleClass="setup-container">

            <padding>
                <Insets top="32" right="32" bottom="32" left="32"/>
            </padding>

            <VBox spacing="4">
                <Label text="Migration Tool Setup" styleClass="page-title"/>
                <Label text="Configure PostgreSQL metadata store before launching the application CLI pipeline."
                       styleClass="page-subtitle" wrapText="true"/>
            </VBox>

            <Separator styleClass="section-separator"/>

            <VBox spacing="14" VBox.vgrow="ALWAYS">

                <VBox spacing="6">
                    <Label text="Database Host Server" styleClass="form-label"/>
                    <TextField fx:id="hostField" promptText="localhost" styleClass="form-input"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Port Configuration" styleClass="form-label"/>
                    <TextField fx:id="portField" promptText="5432" styleClass="form-input"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Username" styleClass="form-label"/>
                    <TextField fx:id="usernameField" promptText="postgres" styleClass="form-input"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Authentication Password" styleClass="form-label"/>
                    <PasswordField fx:id="passwordField" promptText="PostgreSQL Account Password" styleClass="form-input"/>
                </VBox>

            </VBox>

            <HBox spacing="14" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="10"/>
                </padding>
                <Button text="Test Connection"
                        prefWidth="180"
                        onAction="#testConnection"
                        styleClass="btn-secondary"/>

                <Button text="Continue Setup"
                        prefWidth="180"
                        onAction="#continueSetup"
                        styleClass="btn-primary"/>
            </HBox>

        </VBox>
    </children>
</AnchorPane>