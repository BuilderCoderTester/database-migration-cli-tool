<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.project.demo.api.rest.javafx.DatabaseTablesController"
            stylesheets="@css/database_lauout.css">

    <center>
        <!-- SplitPane splits the view into Left List and Right Details -->
        <SplitPane dividerPositions="0.22" styleClass="dashboard-splitpane">
            <items>

                <!-- ================= LEFT PANEL: TABLES LIST ================= -->
                <VBox spacing="16" minWidth="200" maxWidth="400" styleClass="card-panel, sidebar-list-panel">
                    <padding>
                        <Insets top="20" right="16" bottom="20" left="16"/>
                    </padding>

                    <VBox spacing="12">
                        <Label text="Database Tables" styleClass="panel-title-bold"/>
                        <Button text="Refresh"
                                onAction="#refreshMethod"
                        />
                        <Separator styleClass="panel-separator"/>
                    </VBox>

                    <!-- Table ListView with a dynamic placeholder container -->
                    <ListView fx:id="tablesListView" VBox.vgrow="ALWAYS" styleClass="transparent-list-view">
                        <placeholder>
                            <Label text="No tables found" styleClass="table-placeholder-text"/>
                        </placeholder>
                    </ListView>
                </VBox>

                <!-- ================= RIGHT PANEL: TABLE DETAILS ================= -->
                <VBox spacing="12" styleClass="card-panel, detail-viewer-panel" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <!-- Header info stays clean at the top -->
                    <Label text="Select a Table" styleClass="page-title-large"/>
                    <Label text="Choose a table from the left panel to view its structure and rows." styleClass="page-subtitle"/>

                    <!-- Changed to a VBox wrapper so things stack vertically naturally -->
                    <VBox fx:id="tableContentPlaceholder" spacing="20" VBox.vgrow="ALWAYS" styleClass="table-wrapper-pane"/>

                    <!-- Lower footer controls area -->
                    <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="table-footer-actions">
                        <!-- Elements here are safely pinned to the bottom -->
                    </HBox>
                </VBox>
            </items>
        </SplitPane>
    </center>

</BorderPane>