<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>

<VBox prefWidth="550.0" spacing="0" styleClass="modal-container" stylesheets="@css/rollback.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.demo.api.rest.javafx.RollbackDialogController">

    <!-- HEADER SECTION -->
    <HBox alignment="CENTER_LEFT" styleClass="modal-header">
        <padding>
            <Insets bottom="20" left="24" right="24" top="20"/>
        </padding>
        <VBox HBox.hgrow="ALWAYS">
            <Label styleClass="modal-title" text="Rollback Migration"/>
            <Label styleClass="modal-subtitle" text="Migration V8"/>
        </VBox>
        <Button styleClass="close-button">
            <graphic>
                <!-- Close (X) Icon -->
                <SVGPath
                        content="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                        fill="#666666"/>
            </graphic>
        </Button>
    </HBox>

    <Separator/>

    <!-- BODY SECTION -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="modal-body-scroll" vbarPolicy="AS_NEEDED">
        <VBox spacing="16">
            <padding>
                <Insets bottom="24" left="24" right="24" top="24"/>
            </padding>

            <Label styleClass="section-title" text="Select Rollback Strategy"/>

            <!-- Strategy Options (Radio Button Group) -->
            <VBox spacing="12">
                <fx:define>
                    <ToggleGroup fx:id="strategyGroup"/>
                </fx:define>

                <!-- Option 1: Auto Detect (Selected) -->
                <RadioButton fx:id="autoDetectRadio" selected="true" toggleGroup="$strategyGroup"
                             styleClass="strategy-card, strategy-card-selected">
                    <graphic>
                        <VBox spacing="4">
                            <Label styleClass="card-title" text="Auto Detect"/>
                            <Label styleClass="card-description"
                                   text="Automatically determine the best rollback strategy."/>
                        </VBox>
                    </graphic>
                </RadioButton>

                <!-- Option 2: Rollback by Version -->
                <RadioButton fx:id="versionRadio" toggleGroup="$strategyGroup" styleClass="strategy-card">
                    <graphic>
                        <VBox spacing="4">
                            <Label styleClass="card-title" text="Rollback by Version"/>
                            <Label styleClass="card-description"
                                   text="Rollback the database to a selected migration version."/>
                        </VBox>
                    </graphic>
                </RadioButton>

                <!-- Option 3: Rollback CREATE -->
                <RadioButton fx:id="createRadio" toggleGroup="$strategyGroup" styleClass="strategy-card">
                    <graphic>
                        <VBox spacing="4">
                            <Label styleClass="card-title" text="Rollback CREATE"/>
                            <Label styleClass="card-description" text="Rollback CREATE statements only."/>
                        </VBox>
                    </graphic>
                </RadioButton>

                <!-- Option 4: Rollback INSERT -->
                <RadioButton fx:id="insertRadio" toggleGroup="$strategyGroup" styleClass="strategy-card">
                    <graphic>
                        <VBox spacing="4">
                            <Label styleClass="card-title" text="Rollback INSERT"/>
                            <Label styleClass="card-description" text="Rollback INSERT statements only."/>
                        </VBox>
                    </graphic>
                </RadioButton>

                <!-- Option 5: Rollback ALTER -->
                <RadioButton fx:id="alterRadio" toggleGroup="$strategyGroup" styleClass="strategy-card">
                    <graphic>
                        <VBox spacing="4">
                            <Label styleClass="card-title" text="Rollback ALTER"/>
                            <Label styleClass="card-description" text="Rollback ALTER statements only."/>
                        </VBox>
                    </graphic>
                </RadioButton>
            </VBox>

            <!-- WARNING BANNER -->
            <HBox spacing="12" styleClass="warning-banner" alignment="TOP_LEFT">
                <padding>
                    <Insets bottom="16" left="16" right="16" top="16"/>
                </padding>
                <!-- Undo/Warning Icon -->
                <SVGPath
                        content="M12.5 8c-2.65 0-5.05 1-6.9 2.64L2 7v9h9l-3.62-3.62c1.39-1.16 3.16-1.88 5.12-1.88 3.54 0 6.55 2.31 7.6 5.5l2.37-.78C21.08 11.03 17.15 8 12.5 8z"
                        fill="#b45309"/>
                <Label wrapText="true" styleClass="warning-text"
                       text="Rolling back may permanently remove or modify database objects. Please ensure a backup exists before continuing."
                       HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>
    </ScrollPane>

    <Separator/>

    <!-- FOOTER SECTION -->
    <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="modal-footer">
        <padding>
            <Insets bottom="20" left="24" right="24" top="20"/>
        </padding>

        <Button fx:id="cancelButton" onAction="#handleCancel" text="Cancel" styleClass="btn-cancel">
            <graphic>
                <!-- Left Arrow Icon -->
                <SVGPath content="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" fill="#374151"/>
            </graphic>
        </Button>

        <Button fx:id="executeButton" onAction="#handleExecute" text="Execute Rollback" styleClass="btn-execute">
            <graphic>
                <!-- Rollback Loop Icon -->
                <SVGPath
                        content="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"
                        fill="#991b1b"/>
            </graphic>
        </Button>
    </HBox>

</VBox>